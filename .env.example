# ============================================================
# RAG Document Intelligence — Variables de Entorno
# ============================================================
# Copia este fichero como .env y rellena los valores reales.
# NUNCA comitees el fichero .env con claves reales.
# ============================================================

# --- LLM: Anthropic Claude (obligatorio para modo real) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Modo mock (true = sin llamadas reales a la API) ---
# Útil para CI/CD y desarrollo sin consumir créditos
MOCK_LLM=false

# --- Vector Store ---
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=boe_legal_docs

# --- Configuración de la API ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# --- URL de la API (usada por la UI de Streamlit) ---
API_URL=http://localhost:8000

# --- Redis (opcional — caché semántico distribuido) ---
REDIS_URL=

# --- Pinecone (opcional — vector store cloud) ---
PINECONE_API_KEY=

# --- Entorno ---
ENVIRONMENT=development
