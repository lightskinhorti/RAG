# --- Claves y configuración sensible ---
.env
.env.local
.env.*.local
*.pem
*.key

# --- Datos generados localmente ---
data/raw/
data/processed/
data/chroma_db/
data/embeddings_cache/
data/evaluation/results.json

# --- Modelos descargados ---
models/
*.bin
*.pt
*.safetensors

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# --- Entornos virtuales ---
.venv/
venv/
env/
ENV/

# --- Testing y cobertura ---
.pytest_cache/
.coverage
htmlcov/
coverage.xml
nosetests.xml

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Logs ---
*.log
logs/

# --- Streamlit ---
.streamlit/secrets.toml
